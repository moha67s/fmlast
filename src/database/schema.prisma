generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [citext, pg_trgm]
}

model User {
  id                 String   @id @default(cuid())
  discordId          String   @unique @map("discord_id")
  lastfmUsername     String?  @map("lastfm_username") @db.Citext
  lastfmSessionKey   String?  @map("lastfm_session_key")
  lastfmRequestToken String?  @map("lastfm_request_token")
  discogsUsername    String?  @unique @map("discogs_username") @db.Citext
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  settings           Json?

  guilds             GuildMember[]
  userArtists        UserArtist[]
  userTracks         UserTrack[]
  userAlbums         UserAlbum[]
  userPlays          UserPlay[]
  crowns             Crown[]
  crownHistory       CrownHistory[]
  friends            Friend[]       @relation("UserFriends")
  friendedBy         Friend[]       @relation("UserFriendedBy")
  importJobs         ImportJob[]

  @@index([discordId])
  @@index([lastfmUsername])
  @@index([lastfmSessionKey])
  @@map("users")
}

model Guild {
  id         String   @id @default(cuid())
  guildId    String   @unique @map("guild_id")
  createdAt  DateTime @default(now())
  
  members    GuildMember[]
  crowns     Crown[]

  @@index([guildId])
  @@map("guilds")
}

model GuildMember {
  id        String   @id @default(cuid())
  guildId   String   @map("guild_id")
  userId    String   @map("user_id")
  
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
  @@map("guild_members")
}

// ─── Global Metadata Models ───────────────────────────────────────────

model Artist {
  id             String       @id @default(cuid())
  name           String       @unique @db.Citext
  mbid           String?      @unique
  countryCode    String?      @map("country_code")
  type           String?
  gender         String?
  disambiguation String?
  lastfmUrl      String?      @map("lastfm_url")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  links          ArtistLink[]
  tags           ArtistTag[]
  tracks         Track[]
  albums         Album[]
  userArtists    UserArtist[]
  userTracks     UserTrack[]
  userAlbums     UserAlbum[]
  userPlays      UserPlay[]
  crowns         Crown[]

  @@map("artists")
}

model ArtistLink {
  id        String   @id @default(cuid())
  artistId  String   @map("artist_id")
  type      String   // "spotify", "twitter", "instagram", etc.
  url       String
  username  String?
  createdAt DateTime @default(now())

  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, type])
  @@map("artist_links")
}

model Track {
  id         String      @id @default(cuid())
  name       String      @db.Citext
  artistId   String      @map("artist_id")
  mbid       String?     @unique
  duration   Int?        // in seconds
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  artist     Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  userTracks UserTrack[]
  userPlays  UserPlay[]

  @@unique([artistId, name])
  @@map("tracks")
}

model Album {
  id          String      @id @default(cuid())
  name        String      @db.Citext
  artistId    String      @map("artist_id")
  mbid        String?     @unique
  imageLarge  String?     @map("image_large")
  imageMedium String?     @map("image_medium")
  imageSmall  String?     @map("image_small")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  artist      Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  userAlbums  UserAlbum[]
  userPlays   UserPlay[]

  @@unique([artistId, name])
  @@map("albums")
}

// ─── User-Specific Stats Models ───────────────────────────────────────

model UserArtist {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  artistId   String?  @map("artist_id") // Optional relation for ID Resolution backfill
  artistName String   @map("artist_name") @db.Citext
  playcount  Int      @default(0)
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist     Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)

  @@unique([userId, artistName])
  @@index([userId])
  @@index([artistId])
  @@index([artistName])
  @@map("user_artists")
}

model UserTrack {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  trackId    String?  @map("track_id")
  artistId   String?  @map("artist_id")
  artistName String   @map("artist_name") @db.Citext
  trackName  String   @map("track_name") @db.Citext
  playcount  Int      @default(0)
  duration   Int?     @map("duration") // track duration in seconds, populated lazily from Last.fm

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track      Track?   @relation(fields: [trackId], references: [id], onDelete: SetNull)
  artist     Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)

  @@unique([userId, artistName, trackName])
  @@index([userId])
  @@index([trackId])
  @@index([trackName])
  @@map("user_tracks")
}

model UserAlbum {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  albumId    String?  @map("album_id")
  artistId   String?  @map("artist_id")
  artistName String   @map("artist_name") @db.Citext
  albumName  String   @map("album_name") @db.Citext
  playcount  Int      @default(0)
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  album      Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)
  artist     Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)

  @@unique([userId, artistName, albumName])
  @@index([userId])
  @@index([albumId])
  @@index([albumName])
  @@map("user_albums")
}

model UserPlay {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  trackId    String?  @map("track_id")
  artistId   String?  @map("artist_id")
  albumId    String?  @map("album_id")
  artistName String   @map("artist_name") @db.Citext
  trackName  String   @map("track_name") @db.Citext
  albumName  String?  @map("album_name") @db.Citext
  timePlayed DateTime @map("time_played")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track      Track?   @relation(fields: [trackId], references: [id], onDelete: SetNull)
  artist     Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)
  album      Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@unique([userId, timePlayed])
  @@index([userId])
  @@index([trackId])
  @@index([timePlayed])
  @@map("user_plays")
}

model Crown {
  id         String   @id @default(cuid())
  guildId    String   @map("guild_id")
  artistId   String?  @map("artist_id")
  artistName String   @map("artist_name") @db.Citext
  userId     String   @map("user_id")
  playcount        Int      @default(0)
  initialPlaycount Int      @default(0) @map("initial_playcount")
  claimedAt        DateTime @default(now()) @map("claimed_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  guild            Guild    @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist           Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)

  @@unique([guildId, artistName])
  @@index([guildId])
  @@index([userId])
  @@map("crowns")
}

model CrownHistory {
  id               String   @id @default(cuid())
  guildId          String   @map("guild_id")
  artistName       String   @map("artist_name") @db.Citext
  userId           String   @map("user_id")
  playcountAtClaim Int      @map("playcount_at_claim")
  playcountAtLoss  Int?     @map("playcount_at_loss")
  claimedAt        DateTime @map("claimed_at")
  lostAt           DateTime @default(now()) @map("lost_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId, artistName])
  @@map("crown_history")
}

model Friend {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  friendId  String   @map("friend_id")
  status    String   @default("PENDING") // PENDING, ACCEPTED
  createdAt DateTime @default(now())

  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("UserFriendedBy", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@map("friends")
}

model ImportJob {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  source          String   // "SPOTIFY" or "APPLE"
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  totalTracks     Int      @default(0)
  scrobbledTracks Int      @default(0)
  isLegacy        Boolean  @default(false) @map("is_legacy")
  lastProcessedAt DateTime? @map("last_processed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks          ImportTrack[]

  @@map("import_jobs")
}

model ImportTrack {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  artist    String
  track     String
  album     String?
  timestamp Int
  processed Boolean  @default(false)

  job       ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, processed])
  @@unique([jobId, artist, track, timestamp]) // Duplicate prevention
  @@map("import_tracks")
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique @db.Citext
  artists   ArtistTag[]

  @@map("tags")
}

model ArtistTag {
  artistId String @map("artist_id")
  tagId    String @map("tag_id")
  count    Int?   // Optional: Last.fm tag count/relevance

  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([artistId, tagId])
  @@map("artist_tags")
}